{
  "name": "raxwo-mern",
  "version": "1.0.0",
  "description": "Raxwo Technologies MERN Stack Application",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "cd server && npm install && cd ../client && npm install --legacy-peer-deps"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}